# Copy to .env and fill in. yfinance needs no key, so the app runs without these.
# Twelve Data (OHLCV, 800 calls/day free): https://twelvedata.com/
TWELVEDATA_KEY=
# Finnhub (fundamentals + analyst + news, 60 calls/min free): https://finnhub.io/
# Without this key the app runs technicals-only (no fundamentals/analyst/news).
FINNHUB_KEY=
